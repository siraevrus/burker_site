# Полный конфиг виртуального хоста Nginx для burker-watches.ru
# Путь: /etc/nginx/sites-available/burker-watches.ru
# Подключение: sudo ln -s /etc/nginx/sites-available/burker-watches.ru /etc/nginx/sites-enabled/
# Проверка: sudo nginx -t && sudo systemctl reload nginx
#
# Канонический домен: https://burker-watches.ru (без www)
# Все запросы на www перенаправляются 301 на non-www.

# HTTP → HTTPS (всегда на основной домен без www)
server {
    listen 80;
    listen [::]:80;
    server_name burker-watches.ru www.burker-watches.ru;
    return 301 https://burker-watches.ru$request_uri;
}

# HTTPS: www → 301 на non-www
server {
    listen 443 ssl;
    listen [::]:443 ssl;
    server_name www.burker-watches.ru;

    ssl_certificate /etc/letsencrypt/live/burker-watches.ru/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/burker-watches.ru/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    return 301 https://burker-watches.ru$request_uri;
}

# HTTPS: основной сайт (только burker-watches.ru без www)
server {
    listen 443 ssl;
    listen [::]:443 ssl;
    server_name burker-watches.ru;

    client_max_body_size 10M;
    access_log /var/log/nginx/burker-watches.ru_access.log;
    error_log /var/log/nginx/burker-watches.ru_error.log;

    ssl_certificate /etc/letsencrypt/live/burker-watches.ru/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/burker-watches.ru/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    # Статика: загрузки из админки (промоблок, доказательства оплаты)
    # public/promo — не кешируем, чтобы изменения отображались сразу
    location /promo/ {
        alias /var/www/burker-watches.ru/.next/standalone/public/promo/;
        try_files $uri =404;
        access_log off;
        add_header Cache-Control "no-store, no-cache, must-revalidate";
    }

    # Статика: изображения товаров (только файлы с расширением)
    # /products/watches/isabell/... — маршруты Next.js, проксируются в location /
    location ~ ^/products/(.+\.(jpg|jpeg|png|gif|webp|avif))$ {
        alias /var/www/burker-watches.ru/public/products/$1;
        expires 30d;
        access_log off;
    }

    # Страница обслуживания при 502/503/504 (во время деплоя)
    error_page 502 503 504 /maintenance.html;
    location = /maintenance.html {
        root /var/www/burker-watches.ru/public;
        internal;
    }

    # Next.js (standalone)
    location / {
        proxy_pass http://localhost:3010;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;

        proxy_connect_timeout 90s;
        proxy_send_timeout 90s;
        proxy_read_timeout 90s;

        proxy_next_upstream error timeout http_502 http_503;
        proxy_next_upstream_tries 2;
        proxy_next_upstream_timeout 30s;
    }
}
