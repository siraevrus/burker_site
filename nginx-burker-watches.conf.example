# Фрагмент для /etc/nginx/sites-available/burker-watches.ru (или sites-enabled)
# После правок: sudo nginx -t && sudo systemctl reload nginx
# Канонический домен: https://burker-watches.ru (без www). Все www → 301 на non-www.

server {
    listen 80;
    server_name burker-watches.ru www.burker-watches.ru;
    return 301 https://burker-watches.ru$request_uri;
}

# 301 с www на основной домен без www
server {
    listen 443 ssl;
    server_name www.burker-watches.ru;
    ssl_certificate /etc/letsencrypt/live/burker-watches.ru/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/burker-watches.ru/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;
    return 301 https://burker-watches.ru$request_uri;
}

server {
    listen 443 ssl;
    server_name burker-watches.ru;

    client_max_body_size 10M;
    access_log /var/log/nginx/burker-watches.ru_access.log;
    error_log /var/log/nginx/burker-watches.ru_error.log;

    ssl_certificate /etc/letsencrypt/live/burker-watches.ru/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/burker-watches.ru/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    location /promo/ {
        alias /var/www/burker-watches.ru/.next/standalone/public/promo/;
        try_files $uri =404;
        access_log off;
        expires 30d;
    }

    location /products/ {
        alias /var/www/burker-watches.ru/public/products/;
        try_files $uri =404;
        access_log off;
        expires 30d;
    }

    location / {
        proxy_pass http://localhost:3010;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;

        # Меньше 502 при рестартах PM2 и холодном старте Next.js
        proxy_connect_timeout 90s;
        proxy_send_timeout 90s;
        proxy_read_timeout 90s;

        # Повтор запроса при временной недоступности бэкенда
        proxy_next_upstream error timeout http_502 http_503;
        proxy_next_upstream_tries 2;
        proxy_next_upstream_timeout 30s;
    }
}
