# ============================================================================
# PRODUCTION ENVIRONMENT - ПРИМЕР
# Скопируйте этот файл в .env.production и заполните реальные значения
# На сервере: cp .env.production.example .env.production
# ============================================================================

# Database - АБСОЛЮТНЫЙ ПУТЬ (вне директории деплоя)
DATABASE_URL="file:/var/lib/burker-watches/dev.db"

# CDEK API (получите в личном кабинете СДЭК)
CDEK_CLIENT_ID="your-cdek-client-id"
CDEK_CLIENT_SECRET="your-cdek-client-secret"

# Секретный ключ для cron-эндпоинтов (сгенерируйте случайную строку)
CRON_SECRET="your-random-secret-key"

# API парсинга каталога (https://parcing.burker-watches.ru) — заголовок X-API-KEY
API_JSON_KEY="your-api-json-key"

# T-Bank EACQ СБП (оплата заказов): Init + GetQr, подпись Token
# Терминал и пароль — из личного кабинета интернет-эквайринга Т-Бизнес
TBANK_TERMINAL="your-terminal-id"
TBANK_PASSWORD="your-terminal-password"
TBANK_ACCOUNT_NUMBER="your-account-number"
TBANK_SEND_RECEIPT=1
# Опционально: базовый URL (по умолчанию https://securepay.tinkoff.ru)
# TBANK_BASE_URL="https://invoicing.tinkoff.ru"

# Mailopost API — отправка email-уведомлений (https://mailopost.ru)
# Токен — в личном кабинете Mailopost → Настройки → API
MAILOPOST_API_TOKEN="your-mailopost-api-token"
MAILOPOST_FROM_EMAIL="noreply@yourdomain.ru"
MAILOPOST_FROM_NAME="Мира Брендс | Буркер"
# Опционально: другой URL (например резервный api-reserve.msndr.net)
# MAILOPOST_API_URL="https://api.mailopost.ru/v1"

# Admin email — для уведомлений о новых заказах и форме обратной связи
ADMIN_EMAIL="admin@yourdomain.ru"

# Telegram: уведомления (burkeradmin_bot). Chat ID — @userinfobot или ID группы
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""

# Публичный URL сайта (используется в письмах и ссылках)
NEXT_PUBLIC_SITE_URL="https://yourdomain.ru"

# Админ-панель
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="change-me"
ADMIN_JWT_SECRET="change-admin-jwt-secret"

# JWT для входа пользователей (заказы, профиль). Можно = ADMIN_JWT_SECRET
JWT_SECRET="change-jwt-secret"

# Orange Data (фискализация 54-ФЗ)
ORANGEDATA_INN="your-inn"
ORANGEDATA_GROUP="Main_2"
ORANGEDATA_PRIVATE_KEY_PATH="./orange_prod/rsa_private.pem"
ORANGEDATA_CLIENT_CERT_PATH="./orange_prod/your-inn_cert.pfx"
ORANGEDATA_CLIENT_CERT_PASSWORD="your-cert-password"
ORANGEDATA_TLS_INSECURE=1

# Server
PORT=3010
NODE_ENV=production
