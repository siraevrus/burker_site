# Database
DATABASE_URL="file:./prisma/dev.db"

# Базовый URL сайта (канонический, без www — для sitemap, canonical, писем)
SITE_URL="https://burker-watches.ru"
NEXT_PUBLIC_SITE_URL="https://burker-watches.ru"

# CDEK API (Account и Secure password из личного кабинета СДЭК)
# Не коммитить реальные значения в репозиторий.
CDEK_CLIENT_ID=""
CDEK_CLIENT_SECRET=""

# Секретный ключ для cron-эндпоинта обновления курсов валют
CRON_SECRET="your-secret-key-here"

# Mailopost (email рассылки)
# Токен: Личный кабинет Mailopost → Автоматизация → API и SMTP
MAILOPOST_API_TOKEN=""
MAILOPOST_FROM_EMAIL="noreply@yourdomain.ru"
MAILOPOST_FROM_NAME="Mira Brands | Burker"
# Опционально: другой URL (например резервный api-reserve.msndr.net)
# MAILOPOST_API_URL="https://api.mailopost.ru/v1"

# Email администратора (уведомления о новых заказах)
ADMIN_EMAIL=""

# Telegram: уведомления о регистрациях, заказах, курсах, импорте. Chat ID — у @userinfobot или ID группы
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""

# Админ-панель
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="change-me"
ADMIN_JWT_SECRET="change-admin-jwt-secret"

# JWT для входа пользователей (заказы, профиль). Можно использовать тот же ключ, что и ADMIN_JWT_SECRET
JWT_SECRET="change-jwt-secret"

# T-Bank EACQ (оплата заказов): Init → PaymentURL, подпись Token
# Терминал и пароль — из ЛК интернет-эквайринга Т-Бизнес
# TBANK_TERMINAL=""           # для теста: идентификатор должен содержать DEMO
# TBANK_PASSWORD=""
# TBANK_EACQ_BASE_URL=""      # опционально; при DEMO: auto rest-api-test.tinkoff.ru
# TBANK_TOKEN=""              # опционально: Bearer для заголовка

# Orange Data (фискализация 54-ФЗ) — чек при успешной оплате
# Тест: ORANGEDATA_TEST=1 — orange/files_for_test/ (ИНН 3123011520 из docs)
# ORANGEDATA_TEST="1"           # тестовая среда apip.orangedata.ru:2443
# ORANGEDATA_INN="290124976119"
# ORANGEDATA_GROUP="40633"
# ORANGEDATA_API_URL="https://api.orangedata.ru:12003/api/v2/documents/"
# ORANGEDATA_PRIVATE_KEY_PATH="./orange/rsa_2048_private.pem"   # PEM из rsa_2048_private_key.xml
# ORANGEDATA_PRIVATE_KEY_PEM=""                                  # или содержимое PEM в env
# ORANGEDATA_CLIENT_CERT_PATH="./orange/290124976119_40633.pfx"
# ORANGEDATA_CLIENT_CERT_PASSWORD="1234"
