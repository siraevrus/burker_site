# Конфиг виртуального хоста Nginx для TEST стенда
# Путь: /etc/nginx/sites-available/test.burker-watches.ru
# Подключение: sudo ln -s /etc/nginx/sites-available/test.burker-watches.ru /etc/nginx/sites-enabled/
# Проверка: sudo nginx -t && sudo systemctl reload nginx
#
# Защищён HTTP Basic Auth — чтобы Яндекс/Google не индексировали тестовый стенд.
#
# Создание файла паролей:
#   sudo apt install -y apache2-utils
#   sudo htpasswd -c /etc/nginx/.htpasswd_test ваш_логин
#   (введёте пароль в интерактивном режиме)

# HTTP → HTTPS
server {
    listen 80;
    listen [::]:80;
    server_name test.burker-watches.ru;
    return 301 https://test.burker-watches.ru$request_uri;
}

# HTTPS: тестовый стенд
server {
    listen 443 ssl;
    listen [::]:443 ssl;
    server_name test.burker-watches.ru;

    # SSL — отдельный сертификат для поддомена.
    # Получить: sudo certbot certonly --nginx -d test.burker-watches.ru
    ssl_certificate /etc/letsencrypt/live/test.burker-watches.ru/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/test.burker-watches.ru/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    client_max_body_size 10M;
    access_log /var/log/nginx/test.burker-watches.ru_access.log;
    error_log  /var/log/nginx/test.burker-watches.ru_error.log;

    # Basic Auth — блокирует индексацию и случайных посетителей
    auth_basic "Test Stand";
    auth_basic_user_file /etc/nginx/.htpasswd_test;

    # Статика: загрузки из админки
    location /promo/ {
        alias /var/www/test.burker-watches.ru/.next/standalone/public/promo/;
        try_files $uri =404;
        access_log off;
        add_header Cache-Control "no-store, no-cache, must-revalidate";
    }

    location ~ ^/products/(.+\.(jpg|jpeg|png|gif|webp|avif))$ {
        alias /var/www/test.burker-watches.ru/public/products/$1;
        expires 30d;
        access_log off;
    }

    # Next.js (standalone, порт 3011)
    location / {
        proxy_pass http://localhost:3011;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;

        proxy_connect_timeout 90s;
        proxy_send_timeout    90s;
        proxy_read_timeout    90s;

        proxy_next_upstream error timeout http_502 http_503;
        proxy_next_upstream_tries 2;
        proxy_next_upstream_timeout 30s;
    }
}
